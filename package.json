    "test:atdb:write-safety": "node scripts/check-atdb-write-safety.mjs",
    "test:atdb:rebuild-contract": "node scripts/check-atdb-rebuild-contract.mjs",
    "mapping:atdb:check": "node scripts/check-atdb-mapping.mjs"
